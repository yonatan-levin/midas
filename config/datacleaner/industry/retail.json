{
  "gics_code": "25", 
  "name": "Consumer Discretionary - Retail",
  "description": "Retail sector specific rules focusing on inventory management, lease accounting, and seasonal adjustments",
  "overrides": [
    {
      "rule_id": "obsolete_inventory",
      "enabled": true,
      "threshold": {
        "growth_multiple": 1.3,
        "turnover_decline": 0.2,
        "writedown_rate": 0.5
      },
      "severity": "critical"
    },
    {
      "rule_id": "operating_leases",
      "enabled": true,
      "severity": "critical"
    },
    {
      "rule_id": "right_of_use_assets",
      "enabled": true,
      "severity": "warning"
    },
    {
      "rule_id": "working_capital_window_dressing",
      "enabled": true,
      "threshold": {
        "percentage_of_revenue": 0.1
      },
      "severity": "critical"
    }
  ],
  "special_rules": [
    {
      "id": "seasonal_inventory_adjustment",
      "name": "Seasonal Inventory Adjustment",
      "description": "Retail companies have seasonal inventory patterns. Flag unusual inventory levels relative to historical seasonal patterns",
      "category": "asset_quality",
      "xbrl_tags": ["Inventory", "InventoryFinishedGoods", "MerchandiseInventory"],
      "adjustment": "flag",
      "threshold": {
        "percentage_of_revenue": 0.25
      },
      "industry": ["25"],
      "severity": "warning",
      "version": "1.0",
      "enabled": true,
      "source": "Industry_Retail_Seasonal"
    },
    {
      "id": "store_closure_reserves",
      "name": "Store Closure and Restructuring Reserves",
      "description": "Retail companies often over-reserve for store closures. Flag excessive restructuring reserves relative to actual closure activity",
      "category": "liability_completeness",
      "xbrl_tags": ["RestructuringReserves", "StoreClosureReserves", "LeaseTerminationCosts"],
      "adjustment": "flag",
      "threshold": {
        "percentage_of_revenue": 0.03
      },
      "industry": ["25"],
      "severity": "warning",
      "version": "1.0",
      "enabled": true,
      "source": "Industry_Retail_Closure"
    },
    {
      "id": "loyalty_program_liability",
      "name": "Customer Loyalty Program Liability",
      "description": "Retail loyalty programs create contingent liabilities. Ensure adequate reserves for outstanding loyalty obligations",
      "category": "liability_completeness",
      "xbrl_tags": ["CustomerLoyaltyProgramLiability", "DeferredRevenueLoyalty", "RewardsLiability"],
      "adjustment": "flag",
      "threshold": {
        "percentage_of_revenue": 0.02
      },
      "industry": ["25"],
      "severity": "info",
      "version": "1.0",
      "enabled": true,
      "source": "Industry_Retail_Loyalty"
    },
    {
      "id": "gift_card_breakage_income",
      "name": "Gift Card Breakage Income",
      "description": "Retail companies recognize income from unredeemed gift cards. Flag aggressive breakage assumptions or unusual patterns",
      "category": "earnings_normalization",
      "xbrl_tags": ["GiftCardBreakageIncome", "StoredValueCardBreakage", "UnredeemedGiftCards"],
      "adjustment": "flag",
      "threshold": {
        "percentage_of_revenue": 0.01
      },
      "industry": ["25"],
      "severity": "warning",
      "version": "1.0",
      "enabled": true,
      "source": "Industry_Retail_Breakage"
    },
    {
      "id": "vendor_allowances_quality",
      "name": "Vendor Allowances and Rebates",
      "description": "Retail companies receive various vendor allowances. Flag unusual patterns or timing of vendor allowance recognition",
      "category": "earnings_normalization",
      "xbrl_tags": ["VendorAllowances", "VendorRebates", "CooperativeAdvertising"],
      "adjustment": "flag",
      "threshold": {
        "percentage_of_revenue": 0.05
      },
      "industry": ["25"],
      "severity": "info",
      "version": "1.0",
      "enabled": true,
      "source": "Industry_Retail_Allowances"
    },
    {
      "id": "markdown_and_shrinkage_reserves",
      "name": "Markdown and Shrinkage Reserves",
      "description": "Retail companies must reserve for inventory markdowns and shrinkage. Flag inadequate reserves based on historical patterns",
      "category": "asset_quality",
      "xbrl_tags": ["InventoryMarkdownReserve", "ShrinkageReserve", "InventoryObsolescenceReserve"],
      "adjustment": "flag",
      "threshold": {
        "percentage_of_revenue": 0.03
      },
      "industry": ["25"],
      "severity": "warning",
      "version": "1.0",
      "enabled": true,
      "source": "Industry_Retail_Markdown"
    }
  ]
} 