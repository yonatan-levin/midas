# DCF Valuation API Configuration

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# ==============================================================================
# DATABASE CONFIGURATION  
# ==============================================================================
# For development: use SQLite
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/midas.db

# For production: use PostgreSQL
# DATABASE_TYPE=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=midas
# DATABASE_USER=midas_user
# DATABASE_PASSWORD=your_secure_password
# DATABASE_SSL_MODE=require
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5
DATABASE_CONNECTION_MAX_LIFETIME=5m

# ==============================================================================
# CACHE CONFIGURATION
# ==============================================================================
# For development: use memory cache
CACHE_TYPE=memory

# For production: use Redis
# CACHE_TYPE=redis
# CACHE_HOST=localhost
# CACHE_PORT=6379
# CACHE_PASSWORD=
# CACHE_DB=0

# Cache TTL settings
CACHE_TTL_FINANCIAL=24h  # SEC filings change infrequently
CACHE_TTL_MARKET=1h      # Market data needs frequent updates  
CACHE_TTL_VALUATION=30m  # Valuation results need moderate updates

# ==============================================================================
# SEC API CONFIGURATION
# ==============================================================================
SEC_BASE_URL=https://data.sec.gov
SEC_RATE_LIMIT=10                # Requests per second (SEC limit is 10/sec)
SEC_REQUEST_TIMEOUT=30s
SEC_MAX_RETRIES=3
SEC_BACKOFF_MULTIPLIER=2
SEC_USER_AGENT=Midas DCF API/1.0 # Required by SEC

# ==============================================================================
# MARKET DATA CONFIGURATION
# ==============================================================================

# Yahoo Finance Settings
YFINANCE_ENABLED=true
YFINANCE_BASE_URL=https://query1.finance.yahoo.com
YFINANCE_REQUEST_TIMEOUT=15s
YFINANCE_MAX_RETRIES=3

# Finzive Settings (Future implementation)
FINZIVE_ENABLED=false
# FINZIVE_API_KEY=your_finzive_key
# FINZIVE_BASE_URL=https://api.finzive.com

# ==============================================================================
# MACRO DATA CONFIGURATION
# ==============================================================================

# FRED API Settings (Future implementation - Treasury rates)
FRED_ENABLED=false
# FRED_API_KEY=your_fred_api_key
# FRED_BASE_URL=https://api.stlouisfed.org/fred

# Manual macro settings (used when FRED is disabled)
MANUAL_RISK_FREE_RATE=0.045      # 4.5% - 10-year Treasury approximation
MANUAL_MARKET_RISK_PREMIUM=0.05  # 5% - Standard market risk premium

# ==============================================================================
# VALUATION CONFIGURATION
# ==============================================================================
VALUATION_PROJECTION_YEARS=5
VALUATION_MAX_TERMINAL_GROWTH=0.03      # 3% maximum terminal growth
VALUATION_DEFAULT_TAX_RATE=0.21         # 21% corporate tax rate
VALUATION_MIN_BETA=0.1                  # Minimum beta value
VALUATION_MAX_BETA=3.0                  # Maximum beta value
VALUATION_DEFAULT_BETA=1.0              # Default beta when none available

# ==============================================================================
# API LIMITS & PERFORMANCE
# ==============================================================================
API_MAX_BULK_TICKERS=50                 # Maximum tickers per bulk request
API_RATE_LIMIT_PER_MINUTE=60           # API rate limiting
API_MAX_CONCURRENT_REQUESTS=10         # Concurrent request limit

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
LOG_LEVEL=info                         # debug, info, warn, error
LOG_FORMAT=json                        # json or console
LOG_OUTPUT=stdout                      # stdout or file path

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================
# CORS settings
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ==============================================================================
# DEVELOPMENT/TESTING CONFIGURATION
# ==============================================================================
ENV=development                        # development, staging, production
DEBUG=false                           # Enable debug mode
ENABLE_SWAGGER=true                   # Enable Swagger documentation
SWAGGER_HOST=localhost:8080           # Swagger host for documentation

# Test mode settings
TEST_MODE=false                       # Skip external API calls in tests
TEST_DATA_PATH=./testdata            # Path to test data files

# ==============================================================================
# MONITORING & OBSERVABILITY (Future)
# ==============================================================================
# METRICS_ENABLED=false
# METRICS_PORT=9090
# TRACING_ENABLED=false
# TRACING_ENDPOINT=http://localhost:14268/api/traces 