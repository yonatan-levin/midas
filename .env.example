# Midas DCF Valuation API — Example Environment Configuration
#
# Copy this file to `.env` and fill in your values. Most settings have sensible
# defaults that match the environment (development / staging / production); set
# values here only where you need to override the default.
#
# Env-var naming convention: nested YAML keys are joined with underscores and
# uppercased. For example, `database.driver` (config.yaml) → `DATABASE_DRIVER`.
#
# Source of truth for defaults: `internal/config/config.go`.
# See `docs/API_DOCUMENTATION.md` §8 for descriptions of every knob.

# =============================================================================
# 1. Server
# =============================================================================
ENVIRONMENT=development              # development | staging | production
PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
ENABLE_SWAGGER=false                 # exposes /swagger; safe in dev only
ENABLE_PPROF=false                   # exposes /debug/pprof; never enable in prod

# Container-only flags (consumed by docker-entrypoint.sh and Gin)
RUN_MIGRATIONS=true                  # docker-entrypoint.sh: run `cmd/migrate` on start
GIN_MODE=debug                       # Gin framework: debug | release

# =============================================================================
# 2. Database
# =============================================================================
DATABASE_DRIVER=sqlite3              # sqlite3 | postgres
DATABASE_SQLITE_PATH=./data/midas.db
# DATABASE_POSTGRES_URL=postgres://user:pass@host:5432/midas?sslmode=disable
DATABASE_MAX_OPEN_CONN=25
DATABASE_MAX_IDLE_CONN=10

# =============================================================================
# 3. Cache (Redis — optional; falls back to in-memory)
# =============================================================================
CACHE_REDIS_URL=redis://localhost:6379
CACHE_SEC_FILINGS_TTL=48h
CACHE_MARKET_DATA_TTL=15m
CACHE_MACRO_DATA_TTL=4h
CACHE_VALUATION_RESULT_TTL=1h
CACHE_DEFAULT_TTL=30m

# =============================================================================
# 4. SEC EDGAR
# =============================================================================
SEC_BASE_URL=https://data.sec.gov/api/xbrl
SEC_TICKER_MAPPING_URL=https://www.sec.gov/files/company_tickers.json
SEC_USER_AGENT=Midas DCF API your-email@example.com   # SEC policy: must include real contact
SEC_RATE_LIMIT=10                    # requests per second; SEC hard limit
SEC_REQUEST_TIMEOUT=30s
SEC_MAX_RETRIES=3
SEC_RETRY_BACKOFF_BASE=1s

# =============================================================================
# 5. Market Data
# =============================================================================
# Yahoo Finance (primary)
MARKET_YFINANCE_ENABLED=true
MARKET_YFINANCE_BASE_URL=https://query2.finance.yahoo.com
MARKET_YFINANCE_COOKIE_URL=https://fc.yahoo.com
MARKET_YFINANCE_CRUMB_URL=https://query2.finance.yahoo.com/v1/test/getcrumb
MARKET_YFINANCE_REQUEST_TIMEOUT=30s
MARKET_YFINANCE_MAX_RETRIES=3
MARKET_YFINANCE_AUTH_TTL=6h          # cookie+crumb cache duration

# Finzive (fallback scraper)
MARKET_FINZIVE_ENABLED=true
MARKET_FINZIVE_BASE_URL=https://finzive.com
MARKET_FINZIVE_REQUEST_TIMEOUT=60s
MARKET_FINZIVE_MAX_RETRIES=2
MARKET_FINZIVE_USER_AGENT=Mozilla/5.0 (compatible; Midas/1.0)

# =============================================================================
# 6. Macro Data (FRED)
# =============================================================================
MACRO_FRED_ENABLED=false             # true requires MACRO_FRED_API_KEY
MACRO_FRED_BASE_URL=https://api.stlouisfed.org/fred
# MACRO_FRED_API_KEY=                # free at https://fred.stlouisfed.org/docs/api/api_key.html
MACRO_MANUAL_RISK_FREE_RATE=0.045    # used when FRED disabled (4.5%)
MACRO_MANUAL_MARKET_RISK_PREMIUM=0.05 # used when FRED disabled (5%)

# =============================================================================
# 7. Valuation Engine
# =============================================================================
VALUATION_MAX_BULK_SIZE=50           # max tickers per bulk request (1-100)
VALUATION_CACHE_TTL=1h
VALUATION_DATA_FETCH_TIMEOUT=10s
VALUATION_SLOW_REQUEST_THRESHOLD=5s  # log a warning when a valuation exceeds this

# Defaults applied when company-specific data is missing — uncomment to override
# VALUATION_DEFAULT_MARKET_RISK_PREMIUM=0.05
# VALUATION_DEFAULT_TERMINAL_GROWTH_CAP=0.03
# VALUATION_DEFAULT_TAX_RATE=0.21
# VALUATION_DCF_PROJECTION_YEARS=5
# VALUATION_DCF_MAX_GROWTH_RATE=0.5
# VALUATION_DCF_MIN_GROWTH_RATE=-0.3
# VALUATION_DCF_ITERATION_TOLERANCE=0.0001
# VALUATION_DCF_MAX_ITERATIONS=100
# VALUATION_MIN_DATA_POINTS_FOR_GROWTH=2

# =============================================================================
# 8. Data Cleaner
# =============================================================================
DATACLEANER_ENABLED=true
DATACLEANER_RULES_PATH=./config/datacleaner/rules.json
DATACLEANER_INDUSTRY_RULES_PATH=./config/datacleaner/industry
DATACLEANER_SCHEMA_PATH=./config/datacleaner/schema.json
DATACLEANER_MIN_QUALITY_SCORE=60.0
DATACLEANER_HIGH_QUALITY_SCORE=85.0
DATACLEANER_ENABLE_RISK_FLAGS=true
DATACLEANER_ENABLE_CACHING=true
DATACLEANER_CACHE_TTL=6h
DATACLEANER_ENABLE_INDUSTRY_RULES=true
DATACLEANER_ENABLE_AUDIT_TRAIL=true
DATACLEANER_LOG_ADJUSTMENTS=true
DATACLEANER_LOG_FLAGS=true

# AI footnote analysis (optional; off by default until AI service is ready)
DATACLEANER_ENABLE_AI_INTEGRATION=false
# DATACLEANER_AI_SERVICE_URL=
# DATACLEANER_AI_SERVICE_TIMEOUT=30s

# =============================================================================
# 9. Scheduler (background batch refresh)
# =============================================================================
SCHEDULER_ENABLED=false              # opt-in; runs daily watchlist refresh
SCHEDULER_INTERVAL=24h
SCHEDULER_MAX_CONCURRENCY=2

# =============================================================================
# 10. Logging
# =============================================================================
# Most logging knobs have environment-driven defaults (see §8.10 and §10.x in
# docs/API_DOCUMENTATION.md). Uncomment only the overrides you need.

# --- Core ---
# LOGGING_LEVEL=debug                # dev default; staging/prod default = info
# LOGGING_FORMAT=console             # dev default; staging/prod default = json
# LOGGING_TRACE_CALCULATIONS=true    # dev default; staging/prod default = false
# LOGGING_ACCESS_LOG_SKIP_PATHS=/metrics,/health,/ready

# --- Rolling file sink (default ON in dev, OFF in staging/prod) ---
# LOGGING_FILE_ENABLED=true
# LOGGING_FILE_PATH=./logs/midas.log
# LOGGING_FILE_MAX_SIZE_MB=100
# LOGGING_FILE_MAX_BACKUPS=10
# LOGGING_FILE_MAX_AGE_DAYS=14
# LOGGING_FILE_COMPRESS=true

# --- Narrate stream (one Info line per pipeline phase) ---
# LOGGING_NARRATE_ENABLED=true
# LOGGING_NARRATE_SAMPLE_RATE=1.0    # fraction of requests to narrate

# --- Per-request artifact bundles ---
# LOGGING_ARTIFACT_STORE_ENABLED=true  # dev default; staging/prod default = false
# LOGGING_ARTIFACT_STORE_ROOT_PATH=./artifacts
# LOGGING_ARTIFACT_STORE_RETENTION_DAYS=7
# LOGGING_ARTIFACT_STORE_MAX_TOTAL_BYTES=5368709120   # 5 GiB
# LOGGING_ARTIFACT_STORE_QUEUE_SIZE=256
# LOGGING_ARTIFACT_STORE_PENDING_BYTES_CAP=10485760   # 10 MiB

# --- Artifact-store triggers (see §10.5 in API docs) ---
# LOGGING_ARTIFACT_STORE_TRIGGERS_ON_ERROR=false
# LOGGING_ARTIFACT_STORE_TRIGGERS_QUALITY_FLAG_THRESHOLD=    # info | low | warning | medium | high | critical
# LOGGING_ARTIFACT_STORE_TRIGGERS_ALWAYS=false                # short debugging sessions only

# --- Legacy backward-compat ---
# LOG_LEVEL=debug                    # honored when LOGGING_LEVEL is unset
