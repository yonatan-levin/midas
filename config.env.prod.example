# =============================================================================
# Midas DCF Valuation API — PRODUCTION environment template
# =============================================================================
# Target: Docker Compose production (docker-compose.prod.yml). See the runbook:
#   docs/operations/deployment-runbook.md
#
# HOW THIS IS CONSUMED:
#   Copy this file to `.env` NEXT TO docker-compose.prod.yml on the deploy host:
#     cp config.env.prod.example .env  &&  chmod 600 .env
#   Compose interpolates ${VAR} in docker-compose.prod.yml from this `.env`.
#
# RULES:
#   * PLACEHOLDERS ONLY in this committed template — NEVER put a real secret here.
#   * Lines marked "# SECRET" must be supplied via a secrets manager or the host
#     .env at deploy time, and the host .env must NEVER be committed.
#   * An UNDEFINED ${VAR} expands to "" silently at deploy — set every required
#     (REQUIRED) var below or risk a mis-configured container.
#
# NAME SPACES: this file uses the HOST var names the compose file interpolates
#   (e.g. DATABASE_URL). The app inside the container reads a different name
#   (e.g. DATABASE_POSTGRES_URL); the compose file does the mapping. See the
#   env-var contract table in docs/refactoring/spec/tdb-6-cloud-deploy-config-spec.md §4.
# =============================================================================

# ===== Application =====
# These are pinned to literals in docker-compose.prod.yml (ENVIRONMENT=production,
# LOG_LEVEL=info, PORT=8080, GIN_MODE=release). Uncomment to override the pinned value.
#ENVIRONMENT=production          # config default: development. Drives prod logging defaults. (optional)
#LOG_LEVEL=info                  # config default: debug. Legacy level field. (optional)
#PORT=8080                       # config default: 8080. App listen port. (optional)
#SCHEDULER_ENABLED=false         # config default: false. Set true on ONE instance only — replicas double-run. (optional)
#ENABLE_SWAGGER=false            # config default: false. Keep false in prod (no public API explorer). (optional)
#ENABLE_PPROF=false              # config default: false. Keep false in prod (profiling/DoS surface). (optional)
#VALUATION_GUIDANCE_ROOT=        # config default: "" (disabled). Leave EMPTY in prod (Layer-B guidance is fixture-only). (optional)

# ===== Database =====
DATABASE_DRIVER=sqlite3                  # sqlite3 is the ONLY wired driver today; the compose default
#                                          'postgres' is config-accepted but does NOT boot (no lib/pq/pgx
#                                          driver imported) — see deployment-runbook.md §4 caveat #5. (REQUIRED: set sqlite3)
DATABASE_SQLITE_PATH=/app/data/midas.db  # SQLite DB file (persist /app/data via a named volume — runbook §10). (optional, default ./data/midas.db)
RUN_MIGRATIONS=true                      # entrypoint auto-migrates the SQLite DB on boot. (optional)
# SECRET — supply via secrets manager / host .env, never commit
# DATABASE_URL maps to DATABASE_POSTGRES_URL; only used when DATABASE_DRIVER=postgres, which is
# NOT functional yet (no PG driver imported — see DATABASE_DRIVER note + runbook §4). Leave EMPTY
# for the SQLite path. When Postgres support lands, set it (# SECRET — secrets manager, never commit):
#   postgres://user:__password__@host:5432/midas?sslmode=require
DATABASE_URL=                            # empty for SQLite; populate only after Postgres is wired. (optional today)
#DATABASE_MAX_OPEN_CONN=50       # pinned to 50 in compose (config default 25). (optional)
#DATABASE_MAX_IDLE_CONN=10       # pinned to 10 in compose (config default 10). (optional)

# ===== Cache (Redis — OPTIONAL; empty => in-memory fallback) =====
# SECRET — supply via secrets manager / host .env if Redis requires auth, never commit
REDIS_URL=redis://redis-host:6379        # optional. Use rediss://:__password__@host:6379 for TLS+auth. (optional)

# ===== SEC EDGAR =====
SEC_USER_AGENT="Your Company Name admin@yourdomain.com"   # REQUIRED. Real contact email or SEC returns 403. (REQUIRED)
#SEC_RATE_LIMIT=10               # pinned to 10 in compose (SEC cap; do NOT raise). (optional)

# ===== Macro data (FRED) =====
FRED_ENABLED=false                       # compose default: false. true => live FRED macro data. (optional)
# SECRET — supply via secrets manager / host .env, never commit
FRED_API_KEY=__set_in_secrets_manager__  # REQUIRED only when FRED_ENABLED=true. (REQUIRED-if-FRED)
MANUAL_RISK_FREE_RATE=0.045              # fallback risk-free rate (4.5%) when FRED disabled. (optional)
MANUAL_MARKET_RISK_PREMIUM=0.05          # fallback equity risk premium (5%) when FRED disabled. (optional)
#MACRO_FRED_BASE_URL=https://api.stlouisfed.org/fred   # rarely overridden. (optional)

# ===== DataCleaner =====
# All pinned to literals in compose (DATACLEANER_ENABLED=true, rules paths at /app/config/...,
# MIN_QUALITY_SCORE=60.0, ENABLE_CACHING=true, CACHE_TTL=6h). Override hooks below.
#DATACLEANER_ENABLE_AI_INTEGRATION=false # config default: false. Keep false unless an AI service is wired. (optional)
# SECRET — only if the AI service URL embeds a token; supply via secrets manager
#DATACLEANER_AI_SERVICE_URL=             # config default: "". Only with AI integration on. (optional)

# ===== Observability =====
# Prod opts INTO the artifact store, flushing bundles only on 5xx (postmortem capture).
# Both pinned to literals in compose; override hooks below.
#LOGGING_LEVEL=info                       # prod default: info. Set debug only for transient diagnosis. (optional)
#LOGGING_ARTIFACT_STORE_ROOT_PATH=./artifacts   # if on, point at a sized, mounted volume (compose mounts none today). (optional)
#LOGGING_ARTIFACT_STORE_MAX_TOTAL_BYTES=5368709120   # 5 GiB cap on postmortem bundle disk. (optional)

# ===== Auth / Secrets =====
# NOTE: Midas API-key auth is DATABASE-backed — there is NO API_KEY env var.
# Provision keys with cmd/seed-demo-key (first key) or cmd/hash-key (insert an
# externally-generated key). See the runbook §"Secrets handling".

# ===== TLS (Traefik + Let's Encrypt) =====
ACME_EMAIL=admin@yourdomain.com          # REQUIRED. Let's Encrypt registration/expiry email. (REQUIRED)
# NOTE: edit the Host(`api.dcf-valuation.com`) label in docker-compose.prod.yml to YOUR domain.

# ===== Monitoring (Grafana — only with `--profile monitoring`) =====
# SECRET — supply via secrets manager / host .env, never commit
GRAFANA_PASSWORD=__set_in_secrets_manager__   # REQUIRED only with the monitoring profile. (REQUIRED-if-monitoring)

# ===== Build =====
BUILD_DATE=2026-06-09            # compose default: now. ISO date stamped into the image label. (optional)
VERSION=v0.9.0-rc1               # compose default: latest. Release tag; drives the image tag. (optional)
