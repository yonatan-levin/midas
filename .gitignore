### .gitignore for Go projects
# Generated 2025-07-27
# Notes:
# - Keep go.mod and go.sum tracked for reproducible builds.
# - If you purposefully vendor dependencies, uncomment the vendor/ line below.
# - Keep testdata/ (seeds/corpus) in repo; we only ignore fuzz crashers/suppressions.
# - Prefer a secret manager for production; .env* is ignored for local dev convenience.

# Go build artifacts / binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.a

# Common build output directories
bin/
build/
dist/
out/
release/
tmp/
*.tmp

# GoReleaser output
dist/

# Dependency vendoring (uncomment if you vendor)
# vendor/

# Coverage & profiling outputs
coverage.*
*.cover
*.coverprofile
*.cov
cover.out
profile.out
*.prof
*.pprof
coverage/
# Go fuzzing (keep corpus; ignore crashers/suppressions/workdir)
testdata/**/Fuzz*/crashers/
testdata/**/Fuzz*/suppressions/
testdata/**/Fuzz*/workdir/
testdata/**/Fuzz*/minimization/

# Editor / IDE files
.vscode/
.idea/
*.iml
.history/
*.swp
*.swo
*~
.vs/
.codex/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Sublime Text
*.sublime-project
*.sublime-workspace
# Vim
# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*
# OS generated files
.DS_Store
.DS_Store?
Thumbs.db
._*
.Spotlight-V100
.Trashes
ehthumbs.db
*.lnk

# Logs
*.log
logs/
# Ignore everything under artifacts/ EXCEPT the tier2-baseline subtree.
# Bundle captures otherwise pile up locally; the tier2-baseline directory
# holds pre-Tier-2 regression baselines that are checked in. Consumed by
# valuation/profile/tier2_regression_test.go and by future bundle-replay
# verification. See docs/refactoring/implementations/
# assumption-profile-implementation-plan.md Task B.1. Using artifacts/*
# (rather than artifacts/) so the negation can reach into the directory —
# Git skips recursion into a fully-ignored parent.
artifacts/*
!artifacts/tier2-baseline/
*.gz

# Caches (tooling may create these locally)
.cache/
.parcel-cache
.nyc_output
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.node_repl_history

# Environment files (for local dev only)
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# But DO track the canonical template — operators read it to learn the config surface
!.env.example

# Ensure Go module files are not ignored
!go.mod
!go.sum

# Go workspace and cache files
go.work
go-build/
go-mod-cache/
go-test-cache/
go-coverage-cache/
go-tool-cache/
go-debug-cache/
go-sum-cache/
go-proxy-cache/
go-pkg-cache/
go-src-cache/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
*.lcov

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node_modules
node_modules/
# Optional npm cache directory
.npm
# Optional eslint cache
.eslintcache

# Output of 'npm pack'
*.tgz
# Yarn Integrity file
.yarn-integrity

# Next.js build output
.next
# Nuxt.js build / generate output
.nuxt
# Gatsby files
public
# Storybook build outputs
.storybook-out
# Temporary folders
temp/

# Claude Code / Cursor IDE temp files
.claude/worktrees/
.claude/hooks/.session-edits.json
.claude/hooks/.rules-loaded
.claude/ralph-loop.local.md
.claude/settings.local.json
.claude/scheduled_tasks.lock
.cursor/hooks/.session-edits.json

# Git worktrees (superpowers / feature-branch isolation)
.worktrees/

# Database files
*.db
*.sqlite
*.sqlite3

# Redis dump files
dump.rdb

# Docker
.dockerignore
docker-compose.override.yml

# Kubernetes
*.kubeconfig

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Ansible
*.retry

# Packer
packer_cache/

# Vagrant
.vagrant/

# Local development
local/
dev/
development/
# Production builds
# (already covered above: build/, dist/, bin/)

# Configuration files with secrets
config/secrets.yaml
config/secrets.yml
config/secrets.json
config/secrets.toml
config/secrets.ini

# SSL certificates
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# Backup files
*.bak
*.backup
*.old

# Archive files
*.tar
*.tar.gz
*.zip
*.rar
*.7z

# Documentation build
docs/_build/
docs/build/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# pipenv
Pipfile.lock

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# Project specific
# Add any project-specific files or directories here
#testdata/*

# Coverage reports
coverage
*_coverage
coverage.out
*.coverage
*cover*
.hypothesis

# Negations: docs are documentation, never ignored even if names match patterns
# above (e.g. RM-2's "coverage-gaps" filename incidentally matches *cover*).
!docs/**
